# ============================================================================
# DATABASE — Neon Postgres (free tier)
# ============================================================================
# Sign up at https://neon.tech, create project, copy connection string
# Pooled connection (for runtime queries)
DATABASE_URL="postgresql://user:pass@host/dbname?sslmode=require"
# Direct connection (for migrations only)
DIRECT_DATABASE_URL="postgresql://user:pass@host/dbname?sslmode=require"

# ============================================================================
# AUTH — NextAuth v5
# ============================================================================
# Generate with: openssl rand -base64 32
AUTH_SECRET="REPLACE_WITH_RANDOM_32_BYTE_BASE64"
AUTH_URL="https://planner.atozfamily.org"
# In dev: AUTH_URL="http://localhost:3000"

# ============================================================================
# EMAIL — Resend (magic link sender)
# ============================================================================
# Sign up at https://resend.com, verify atozfamily.org domain, create API key
RESEND_API_KEY="re_xxxxxxxxxxxxxxxxxxxxxxxxx"
EMAIL_FROM="planner@atozfamily.org"

# ============================================================================
# ACCESS CONTROL — Allowlist
# ============================================================================
# Comma-separated list of authorized email addresses
# Only these emails can sign in. All others are rejected.
ALLOWED_EMAILS="you@example.com,your-wife@example.com"

# ============================================================================
# OPTIONAL (Phase 2)
# ============================================================================
# Vercel Blob for photo upload
# BLOB_READ_WRITE_TOKEN=""
